      {
        "parameters": {
          "operation": "executeQuery",
          "query": "INSERT INTO conversation_state (phone, state, name, product, address, last_message)\nVALUES ($1, $2, NULLIF($3, ''), NULLIF($4, ''), NULLIF($5, ''), $6)\nON CONFLICT (phone) DO UPDATE SET\n  state = EXCLUDED.state,\n  name = COALESCE(EXCLUDED.name, conversation_state.name),\n  product = COALESCE(EXCLUDED.product, conversation_state.product),\n  address = COALESCE(EXCLUDED.address, conversation_state.address),\n  last_message = EXCLUDED.last_message,\n  updated_at = NOW()\nRETURNING phone, state, name, product, address, last_message, $7::text AS reply_text;",
          "options": {
            "queryReplacement": "={{ [$json.phone, $json.next_state, $json.customer_name, $json.product, $json.address, $json.incoming_message, $json.reply_text] }}"
          }
        },
