      {
        "parameters": {
          "operation": "executeQuery",
          "query": "SELECT\n  $1::text AS phone,\n  $2::text AS incoming_message,\n  $3::text AS contact_name,\n  COALESCE((SELECT state FROM conversation_state WHERE phone = $1), 'idle') AS current_state,\n  COALESCE((SELECT name FROM conversation_state WHERE phone = $1), '') AS stored_name,\n  COALESCE((SELECT product FROM conversation_state WHERE phone = $1), '') AS stored_product,\n  COALESCE((SELECT address FROM conversation_state WHERE phone = $1), '') AS stored_address;",
          "options": {
            "queryReplacement": "={{ [$json.phone, $json.incoming_message, $json.contact_name] }}"
          }
        },
